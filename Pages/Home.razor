@page "/"
@using MudBlazor
@inject IJSRuntime js
@inject ISnackbar Snackbar


<MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center" Class="mt-4">مواعيد المستشفى - لنواف 🏥</MudText>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenAddDialog" Class="my-4">
        إضافة موعد جديد +
    </MudButton>

    <MudTable Items="@appointments" Filter="new Func<Appointment, bool>(FilterFunc)">
        <ToolBarContent>
            <MudText Typo="Typo.h6">قائمة المواعيد</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="بحث..." Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>الطبيب</MudTh>
            <MudTh>المستشفى</MudTh>
            <MudTh>التاريخ والوقت</MudTh>
            <MudTh>ملاحظات</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="الطبيب">@context.DoctorName</MudTd>
            <MudTd DataLabel="المستشفى">@context.HospitalName</MudTd>
            @* تحسين طريقة عرض التاريخ ليظهر الوقت معه في الجدول *@
            <MudTd DataLabel="التاريخ والوقت">@context.Date?.ToString("yyyy-MM-dd hh:mm tt")</MudTd>
            <MudTd DataLabel="ملاحظات">@context.Note</MudTd>
            <MudTd DataLabel="إجراءات">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info"
                               OnClick="@(() => PrepareEdit(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               OnClick="@(() => DeleteAppointment(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>
<MudDialog @bind-Visible="isDialogVisible" Options="dialogOptions">
        <TitleContent>
        <MudText Typo="Typo.h6">@(string.IsNullOrEmpty(newAppointment.Id) ? "إضافة موعد جديد" : "تعديل الموعد")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form">

        <MudTextField T="string" Label="اسم الطبيب" @bind-Value="newAppointment.DoctorName" 
                          Variant="Variant.Outlined" Class="mb-3"
                          Required="true" RequiredError="يجب كتابة اسم الطبيب" />
        
        <MudSelect T="string" Label="اختر المستشفى" @bind-Value="selectedHospital" 
                       Variant="Variant.Outlined" Class="mb-3"
                       Required="true" RequiredError="يرجى اختيار المستشفى">
                @foreach (var hospital in hospitals)
                {
                    <MudSelectItem Value="@hospital">@hospital</MudSelectItem>
                }
            </MudSelect>

       @if (showOtherHospitalInput)
            {
                <MudTextField T="string" Label="اكتب اسم المستشفى هنا" @bind-Value="newAppointment.HospitalName"
                              Variant="Variant.Outlined" Class="mb-3"
                              Required="true" RequiredError="يرجى كتابة اسم المستشفى" />
            }

 <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="التاريخ" @bind-Date="newAppointment.Date" 
                                   Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTimePicker Label="الوقت" @bind-Time="newAppointment.Time" 
                                   Variant="Variant.Outlined" Required="true" />
                </MudItem>
            </MudGrid>

        <MudTextField T="string" Label="ملاحظات ان وجدت" @bind-Value="newAppointment.Note" Variant="Variant.Outlined"
                      Lines="3" Class="mt-3" />
                      </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">إلغاء</MudButton>
        <MudButton Color="Color.Primary" OnClick="SaveAppointment" Variant="Variant.Filled">حفظ الموعد</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<string> hospitals = new List<string> { "مستشفى صحار", "مستشفى السلطاني", "المركز الصحي صحار", "أخرى" };
    private string? selectedHospital;
    private bool showOtherHospitalInput => selectedHospital == "أخرى";

    private bool isDialogVisible;
    private string searchString = "";
   private DialogOptions dialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Small };

    private List<Appointment> appointments = new List<Appointment>();
    private Appointment newAppointment = new Appointment();
        private MudForm form;


    public class Appointment
    {
        public string? Id { get; set; } 
        public string? DoctorName { get; set; }
        public string? HospitalName { get; set; }
        public DateTime? Date { get; set; }
        
        // قمنا بإلغاء المتغير المعقد هنا والاعتماد على دمجهم في حقل التاريخ لتجنب مشاكل الجافا سكريبت
        [System.Text.Json.Serialization.JsonIgnore]
        public TimeSpan? Time { get; set; }
        
        public string? Note { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAppointments();
    }

    private async Task LoadAppointments()
    {
        try
        {
            // جلب المواعيد كـ كائن ديناميكي مرن أولاً لتفادي انهيار المتصفح
            var result = await js.InvokeAsync<List<Appointment>>("loadFromFirebase");
            if (result != null)
            {
                appointments = result;
                
                // استرجاع الوقت للمكونات بناءً على التاريخ المحفوظ
                foreach(var app in appointments)
                {
                    if(app.Date.HasValue)
                    {
                        app.Time = app.Date.Value.TimeOfDay;
                    }
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private void OpenAddDialog()
    {
        newAppointment = new Appointment();
        newAppointment.Date = DateTime.Today; 
        newAppointment.Time = DateTime.Now.TimeOfDay;

        selectedHospital = null;
        isDialogVisible = true;
    }

    private async Task SaveAppointment()
    {

        // أولاً: نطلب من الـ Form التأكد من أن كل الحقول المطلوبة معبأة
    await form.ValidateAsync();

    // إذا كان الـ Form غير صالح (فيه حقول ناقصة)، نوقف العملية فوراً
    if (!form.IsValid)
    {
        return; 
    }
    
        if (selectedHospital != "أخرى" && !string.IsNullOrEmpty(selectedHospital))
        {
            newAppointment.HospitalName = selectedHospital;
        }

        if (newAppointment.Date.HasValue && newAppointment.Time.HasValue)
        {
            // دمج التاريخ والوقت في حقل واحد قبل الإرسال لـ Firebase لضمان الأمان البنيوي للبيانات
            newAppointment.Date = newAppointment.Date.Value.Date + newAppointment.Time.Value;
        }

    // ================= [ الشرط الجديد هنا ] =================
    if (newAppointment.Date.HasValue)
    {
        // الفحص: نبحث في القائمة عن موعد له نفس التاريخ والوقت تماماً، 
        // وتأكدنا أن الـ Id مختلف لكي لا يظهر التنبيه بالخطأ أثناء عملية "التعديل"
        bool isConflict = appointments.Any(app => 
            app.Date == newAppointment.Date && 
            app.Id != newAppointment.Id);

        if (isConflict)
        {
            // إظهار تنبيه أحمر يختفي بعد ثوانٍ يمنع الحفظ
            Snackbar.Add("تنبيه: يوجد موعد آخر مسجل في نفس هذا اليوم والوقت!", Severity.Warning);
            return; // إيقاف الدالة فوراً ومنع الرفع إلى Firebase
        }
    }
    // =======================================================

        await js.InvokeVoidAsync("saveToFirebase", newAppointment);

        isDialogVisible = false;
        selectedHospital = null;

        await LoadAppointments();

        Snackbar.Add("تم حفظ الموعد بنجاح", Severity.Success);
    }

    private void Cancel() => isDialogVisible = false;

    private bool FilterFunc(Appointment element)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (element.DoctorName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) return true;
        if (element.HospitalName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) return true;
        return false;
    }

    private void PrepareEdit(Appointment appointment)
    {
        newAppointment = new Appointment
        {
            Id = appointment.Id,
            DoctorName = appointment.DoctorName,
            HospitalName = appointment.HospitalName,
            Date = appointment.Date,
            Time = appointment.Date?.TimeOfDay, // تعبئة الوقت في نافذة التعديل
            Note = appointment.Note
        };
        selectedHospital = hospitals.Contains(appointment.HospitalName ?? "") ? appointment.HospitalName : "أخرى";
        isDialogVisible = true;
    }

    private async Task DeleteAppointment(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;

        await js.InvokeVoidAsync("deleteFromFirebase", id);
        await LoadAppointments(); 
    }

}